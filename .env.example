# ── AI Engine ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── OpenRouter (used for embeddings + AI fallback) ────────────────────────────
# Get free key at: https://openrouter.ai
# Used for: ChromaDB embeddings (text-embedding-3-small, ~$0.03 per full index)
# Falls back to Gemini if not set
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Case Law Sources ──────────────────────────────────────────────────────────
INDIAN_KANOON_API_KEY=your_ik_api_key_here

# ── Web Search (Source ⑦) — add either Google OR Bing (or both) ──────────────
# Google Custom Search Engine
#   Setup: https://programmablesearchengine.google.com/ → new engine → entire web
#   API:   Google Cloud Console → enable "Custom Search API" → create key
GOOGLE_CSE_API_KEY=your_google_cse_api_key_here
GOOGLE_CSE_ID=your_search_engine_cx_id_here

# Bing Web Search v7 (Azure free tier: 1,000 queries/month)
#   Setup: https://portal.azure.com → "Bing Search v7" → Keys and Endpoint
BING_SEARCH_API_KEY=your_bing_api_key_here
